{
  "name": "fossil-beans",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "check": "pnpm cf-typegen && tsc --noEmit",
    "cf-typegen": "wrangler types --env-file /dev/null",
    "postinstall": "pnpm run cf-typegen",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply fossil-beans --local",
    "db:migrate:remote": "wrangler d1 migrations apply fossil-beans --remote",
    "db:studio": "drizzle-kit studio",
    "seed:teams:local": "./scripts/insert-teams.sh --local",
    "seed:teams:remote": "./scripts/insert-teams.sh --remote",
    "seed:games:local": "./scripts/insert-games.sh --local",
    "seed:games:remote": "./scripts/insert-games.sh --remote",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^1.24.0",
    "posthog-js": "^1.399.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  },
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba"
}
