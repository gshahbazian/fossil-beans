{
  "name": "fossil-beans",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "check": "pnpm cf-typegen && tsc --noEmit",
    "cf-typegen": "wrangler types",
    "postinstall": "npm run cf-typegen",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply fossil-beans --local",
    "db:migrate:remote": "wrangler d1 migrations apply fossil-beans --remote",
    "db:studio": "drizzle-kit studio",
    "seed:teams:local": "./scripts/insert-teams.sh --local",
    "seed:teams:remote": "./scripts/insert-teams.sh --remote",
    "seed:games:local": "./scripts/insert-games.sh --local",
    "seed:games:remote": "./scripts/insert-games.sh --remote",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^1.23.0",
    "posthog-js": "^1.396.6",
    "radix-ui": "^1.6.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "wrangler": "^4.107.0"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
